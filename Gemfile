source 'https://rubygems.org'

# Use individual gems instead of github-pages meta-gem
# (github-pages 206 requires nokogiri 1.10.x which doesn't compile on Ruby 3.4+)
# Jekyll 3.9.5 has better Ruby 3.4 compatibility than 3.8.7
gem 'jekyll', '3.9.5'
gem 'jekyll-sass-converter', '1.5.2'
gem 'jekyll-paginate', '1.1.0'
gem 'jekyll-feed', '0.13.0'
gem 'jekyll-seo-tag', '2.6.1'
gem 'jekyll-redirect-from', '0.15.0'
gem 'jekyll-sitemap', '1.4.0'
gem 'jekyll-gist', '1.5.0'
gem 'kramdown', '2.5.1'
gem 'kramdown-parser-gfm', '1.1.0'
gem 'rouge', '3.19.0'
gem 'liquid', '4.0.4'
gem 'safe_yaml', '1.0.5'
# Ruby 3.4+ bundled gems that need to be explicit
gem 'csv'
gem 'base64'
gem 'bigdecimal'
gem 'rexml'
gem 'webrick'
# jekyll-admin requires webrick (local dev only, not used in CI build)
gem 'jekyll-admin', group: :jekyll_plugins
